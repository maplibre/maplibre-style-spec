    {
      "id": "invalid-operator",
      "type": "line",
      "source": "source",
      "source-layer": "source-layer",
      "filter": [
        "=",
        "key",
        "value"
      ]
    },
    {
      "id": "missing-key",
      "type": "line",
      "source": "source",
      "source-layer": "source-layer",
      "filter": ["=="]
