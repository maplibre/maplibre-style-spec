{
  "version": 8,
  "sources": {
    "v": {
      "type": "vector",
      "url": "https://demotiles.maplibre.org/tiles/tiles.json"
    }
  },
  "layers": [
    {
      "id": "fill-literal",
      "type": "fill",
      "source": "v",
      "source-layer": "layer",
      "paint": {
        "layer-opacity": 0.5
      }
    },
    {
      "id": "line-zoom-expr",
      "type": "line",
      "source": "v",
      "source-layer": "layer",
      "paint": {
        "layer-opacity": ["interpolate", ["linear"], ["zoom"], 5, 0, 10, 1]
      }
    },
    {
      "id": "fill-with-transition",
      "type": "fill",
      "source": "v",
      "source-layer": "layer",
      "paint": {
        "layer-opacity": 0.8,
        "layer-opacity-transition": {
          "duration": 300,
          "delay": 0
        }
      }
    }
  ]
}
